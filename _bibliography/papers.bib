@mastersthesis{sharma2024obfi,
  title     = {{OBFI}: Oblivious Protocols for Privacy-Preserving Inference},
  author    = {Sharma, Rahil},
  year      = {2024},
  school    = {Vrije Universiteit Amsterdam and University of Amsterdam},
  abstract  = {This thesis introduces OBFI, a framework for privacy-preserving
               inference over encrypted data using oblivious protocols. OBFI enables
               model evaluation without revealing input data or model parameters,
               grounding the construction in secure multi-party computation (SMPC)
               and oblivious data structures. We characterise the information-leakage
               profile of the protocol and evaluate it on real-world classification
               tasks, demonstrating practical performance at competitive accuracy
               thresholds.},
  keywords  = {oblivious computation, privacy-preserving ML, SMPC, cryptographic systems},
  selected  = {true},
  note      = {MSc thesis, VU \texttimes{} UvA}
}

@techreport{sharma2024pacshap,
  title     = {{PACSHAP}: Knowledge-Graph-Augmented {SHAP} Explanations},
  author    = {Sharma, Rahil},
  year      = {2024},
  institution = {Vrije Universiteit Amsterdam},
  abstract  = {We introduce PACSHAP, a framework that integrates SHAP-based feature
               attribution with knowledge graph structure to produce semantically
               grounded, graph-aware model explanations. PACSHAP propagates SHAP
               values across typed graph edges, weighting attributions by ontological
               relationships, and surfaces explanations that align with domain
               knowledge. We evaluate on financial transaction graphs and demonstrate
               improved explanation coherence and reduced instability over standard
               SHAP baselines.},
  keywords  = {explainability, SHAP, knowledge graphs, XAI, fraud detection},
  selected  = {true}
}
